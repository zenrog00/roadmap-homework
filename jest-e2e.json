{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^file-type$": "<rootDir>/test/mocks/file-type.mock.ts"
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!uuid)"
  ],
  "globalSetup": "<rootDir>/test/utils/setup/global-setup.ts",
  "globalTeardown": "<rootDir>/test/utils/setup/global-teardown.ts"
}
